# ==============================================================================
# Configuration de l'application « Radio CR Manager »
# Backend Laravel pour la gestion des comptes rendus de radiologie (Yaoundé).
# Copiez ce fichier en .env puis ajustez les valeurs selon votre environnement.
# ==============================================================================

APP_NAME="Radio CR Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Toute l'interface (admin + PWA) est en français — ne pas changer.
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Base de données --------------------------------------------------------
# MySQL 8 (ou MariaDB) est la cible de production imposée par le cahier des
# charges. En développement local sans serveur MySQL, vous pouvez basculer
# temporairement DB_CONNECTION=sqlite (voir README, section installation).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=radio_cr_manager
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# Expiration de session admin : 120 min. La PWA gère elle-même sa
# déconnexion pour inactivité (15 min) via l'endpoint /api/v1/heartbeat.
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Files d'attente : transcription audio, génération DOCX/PDF, sauvegardes.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Courrier électronique ---------------------------------------------------
# Utilisé pour : réinitialisation de mot de passe, code de connexion à deux
# facteurs, alertes de sauvegarde échouée.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@radio-cr-manager.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Sauvegardes distantes (optionnel, S3-compatible) -----------------------
BACKUP_DISK=local
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=
# BACKUP_S3_ENDPOINT=

# --- Proxys IA (clés stockées chiffrées en base, ceci sert de repli/seed) --
# Voir l'écran admin « Clés API » : les clés sont saisies et chiffrées en
# base de données (table api_credentials). Ces variables ne sont utilisées
# que si aucune clé n'est encore configurée en base.
GROQ_API_KEY=
# GROQ_STT_MODEL=whisper-large-v3-turbo
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- LibreOffice headless (conversion DOCX -> PDF) --------------------------
LIBREOFFICE_BINARY=/usr/bin/soffice

VITE_APP_NAME="${APP_NAME}"
